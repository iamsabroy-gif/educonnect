# Which database backend to use: "postgres" (default) or "turso".
# Switching requires a redeploy/restart, not a live toggle.
DB_DRIVER=postgres

# Postgres connection string, used when DB_DRIVER=postgres. The app creates
# its schema and demo seed data automatically on first request against an
# empty database.
#
# Local dev:    postgres://<your-os-user>@localhost:5432/educonnect
# Neon:         use the pooled connection string (Neon dashboard -> Connect -> Pooled connection):
#               postgresql://<user>:<password>@<endpoint>-pooler.<region>.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Turso/libSQL connection, used when DB_DRIVER=turso. For local testing with
# no Turso account, use a local file: TURSO_DATABASE_URL=file:./data/local.db
# (leave TURSO_AUTH_TOKEN unset for local file mode). For a real Turso
# database, use its libsql:// URL and auth token from the Turso dashboard/CLI.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Static credentials for the /admin console, independent of the app's own
# users/login. Leave either unset to disable admin login entirely.
ADMIN_USERNAME=
ADMIN_PASSWORD=
