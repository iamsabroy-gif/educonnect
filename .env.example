# Postgres connection string. The app creates its schema and demo seed data
# automatically on first request against an empty database.
#
# Local dev:    postgres://<your-os-user>@localhost:5432/educonnect
# Neon:         use the pooled connection string (Neon dashboard -> Connect -> Pooled connection):
#               postgresql://<user>:<password>@<endpoint>-pooler.<region>.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Static credentials for the /admin console, independent of the app's own
# users/login. Leave either unset to disable admin login entirely.
ADMIN_USERNAME=
ADMIN_PASSWORD=
